package arithmetic;
import java.util.Scanner;

public class Arithmetic {

	public static void main(String[] args) {
		//creating the scanner
		Scanner scanner = new Scanner(System.in);

		//intial question of item, records in variable
        System.out.print("What item would you like to buy? ");
        String item = scanner.nextLine();

		//declaration of variables outside of try catch
		int dollars = 0;
		int cents = 0;

		//to stop users making invalid inputs, while doing correct calculations
        while (true) {
			System.out.print("What is the price per item (like 12.99)? ");
        	String priceInput = scanner.next();

			try {
        		String[] parts = priceInput.split("\\.");
        		int dollars = Integer.parseInt(parts[0]);
        		int cents = Integer.parseInt(parts[1]);

				if (dollars >= 0 && cents >= 0) {
					break;
				} else {
					System.out.println("Invalid input, negative numbers not allowed");
				}
			} catch (Exception e) {
				System.out.println("invalid format. Please include both dollars and cents (e.g., 12.99).");
			}
		}
        int priceInCents = dollars * 100 + cents;

        System.out.print("How many would you like? ");
        int quantity = scanner.nextInt();

        int totalInCents = priceInCents * quantity;

        System.out.println("You have purchased " + quantity + " " + item + "s.");

        System.out.printf("Total = $%d.%02d\n",
                totalInCents / 100,
                totalInCents % 100);

        scanner.close();
				
				

			}
	}
